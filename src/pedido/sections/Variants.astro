---
import CrossIcon from "@assets/cross.svg";
import { getCldImageUrl } from "astro-cloudinary/helpers";
---

<dialog id="variants-dialog" class="text-white mt-auto max-w-125 bg-transparent max-h-full">
    <div class="h-fit bg-(--text-brand) rounded-t-3xl py-2.5 flex flex-col gap-4">
        <button id="variants-close-button" class="w-fit p-0! bg-(--accent) rounded-full self-end mr-2.5">
            <CrossIcon
                width={30}
                height={30}
                fill="bg-(--color-text)"
                class:list={"pointer-events-none group-active:fill-(--color-active-secondary)"}
            />
        </button>
        <div class="flex gap-2.5 px-2.5 shrink-0">
            <figure id="variants-product-figure">
                <img id="variants-product-image" src="" alt="" width="160" height="160" class="aspect-square w-[30vw] max-w-40 rounded-xl object-cover" >
            </figure>
            <div class="flex flex-col gap-2">
                <p id="variants-product-name" class="font-bold"></p>
                <p id="variants-product-description" class="text-sm"></p>
                <p id="variants-product-price" class="font-bold text-end"></p>
            </div>
        </div>
        <form id="variants-form" class="px-2.5">
        </form>
        <div class="font-bold flex justify-center gap-4 my-4 px-2.5">
            <button id="variants-back-button"
                class="variant-button"
            >Volver</button>
            <button id="variants-add-button"
                aria-label="Añadir al carrito"
                data-productid=""
                type="submit" 
                form="variants-form"  
                class="disabled:opacity-50 variant-button"
                disabled
            >Añadir</button>
        </div>
    </div>
</dialog>

<script src="../../scripts/order/variants.js"></script>

<style is:global>
    @import "tailwindcss";
    option{
        @apply text-black;
    }
    .variant-button{
        @apply px-5 py-1 rounded-full bg-(--accent) text-white;
    }
    #variants-form{
        @apply flex flex-col gap-6;
    }
    .variant-group{
        @apply flex flex-col gap-2;
    }
    .variant-group-title{
        @apply px-3 py-0.5 rounded-full bg-(--accent) text-white w-fit font-bold;
    }
    .variant-options{
        @apply flex gap-8;
    }
    .variant-option{
        @apply flex gap-3 items-center;
    }
    .variant-options-select{
        @apply grid grid-cols-2 gap-2;
        div select {
            @apply w-full rounded-full border border-gray-300 py-1 px-2 text-sm;
        }
    }
    .variant-ingredients{
        @apply flex flex-wrap gap-4;
    }
    .variant-ingredient-option{
        @apply flex gap-1 items-center;
    }
    .variant-ingredient-option input[type="checkbox"]{
        @apply w-4 h-4 rounded border-gray-300 text-(--accent);
    }

</style>
