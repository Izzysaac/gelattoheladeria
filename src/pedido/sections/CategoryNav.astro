<style is:global>
    .category-nav {
        width: 100vw;
    }

    .category-nav ul {
        overflow: scroll;
        scroll-snap-type: x mandatory;
        scroll-behavior: smooth;
        padding: 0.5rem 0rem;
        list-style: none;
    }
    .category-nav ul::-webkit-scrollbar {
        display: none;
    }

    .category-nav button {
        display: block;
        padding: 0.5rem 0.75rem;
        white-space: nowrap;
        text-decoration: none;
    }

    .category-nav button:focus-visible {
        outline: 2px solid black;
        outline-offset: 2px;
    }
    .category-nav button.active {
        font-weight: 700;
        color: var(--color-navmenu-active);
    }

    .linea {
        position: relative;
        height: 3px;
        background-color: var(--color-border);
    }

    .linea-activa:after {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        top: 0;
        height: 3px;
        background-color: var(--color-navmenu-active);
        border-radius: 999px;
    }

    .active {
        color: purple;
        font-weight: 700;
    }
</style>

<script src="src/scripts/menu/newNavigation.js"></script>
