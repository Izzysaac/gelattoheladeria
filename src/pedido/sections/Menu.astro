---
import { formatFromThousands, formatPrice } from "@scripts/utils.js";
import Plus from "@assets/plus-svgrepo-com.svg";
import Minus from "@assets/minus-svgrepo-com.svg";
import Variants from "./Variants.astro";
import { getCldImageUrl } from "astro-cloudinary/helpers";
const { menuPorCategoria, modo } = Astro.props;
---
<section id="menu" class="menu w-full max-w-200 px-3">
    {
        Object.entries(menuPorCategoria).map(([categoria, items]) => (
            <div class="grupo" id={categoria}>
                <h2 class="mt-6 text-xl text-bold">{categoria}</h2>
                <ul>
                    {(items as any)
                        .filter((item) => item.activo)
                        .map((item: any) => (
                            <li>
                                <article
                                    class="producto flex min-h-25 justify-start gap-2.5 border-b border-(--color-border) py-4"
                                    data-nombre={item.nombre}
                                    data-precio={item.precio}
                                    data-descripcion={item.descripcion}
                                    data-imagen={getCldImageUrl({src: item.imagen, width: 480, height: 480})}
                                >
                                    <div class="informacion flex w-full flex-col self-stretch">
                                        <div class="flex justify-between gap-2">
                                            <h3 class="text-semibold">{item.nombre}</h3>
                                            <p class="mr-2 text-nowrap">
                                                {formatPrice(item.precio)}
                                            </p>
                                        </div>
                                        <p class="pr-8 text-sm text-pretty opacity-90">
                                            {item.descripcion}
                                        </p>
                                        {modo !== "menu" && (    
                                            <div class="controles mt-auto flex w-fit items-center self-end rounded-full bg-(--color-secondary) select-none">
                                                {item.hasVariants == false && (
                                                    <button data-action="remove-product"
                                                        class="remove cerrado"
                                                        aria-label="Quitar del pedido"
                                                        data-productid={item.id}
                                                    >
                                                        <Minus
                                                            width={25}
                                                            height={25}
                                                        />
                                                    </button>
                                                )}
                                                <output class="cantidad cerrado mx-1">
                                                    0
                                                </output>
                                                <button data-action="add-product"
                                                    class="add cerrado"
                                                    aria-label="Agregar al pedido"
                                                    data-productid={item.id}
                                                >
                                                    <Plus
                                                        width={25}
                                                        height={25}
                                                    />
                                                </button>
                                            </div>
                                        )}
                                    </div>
                                    {item.imagen && (
                                        <figure class="order-first shrink-0">
                                            <img
                                                src={getCldImageUrl({
                                                    src: item.imagen,
                                                    width: 480,
                                                    height: 480,
                                                })}
                                                width={160}
                                                height={160}
                                                data-image={getCldImageUrl({
                                                    src: item.imagen,
                                                    width: 800,
                                                    height: 800,
                                                })}
                                                alt={item.nombre}
                                                loading="lazy"
                                                data-action="view-image"
                                                class="aspect-square w-[30vw] max-w-40 rounded-xl object-cover"
                                            />
                                        </figure>
                                    )}
                                </article>
                            </li>
                        ))}
                </ul>
            </div>
        ))
    }
<Variants />
</section>

<style>
    @import "tailwindcss";
    .grupo {
        scroll-margin-top: 5rem; /* altura del nav */
    }
    button {
        @apply px-1.5 py-1.5 cursor-pointer rounded-full active:bg-(--color-active-secondary);
    }
    svg{
        pointer-events: none;
    }
</style>
