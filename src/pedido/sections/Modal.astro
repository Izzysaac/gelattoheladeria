---
import ProductoTemplate from "@pedido/components/ProductoTemplate.astro";
import BorrarPedido from "@pedido/sections/BorrarPedido.astro";
import StickyBar from "@components/sections/StickyBar.astro";
import ModalTopBar from "@components/ui/ModalTopBar.astro";

const { mode } = Astro.props;
---

<dialog
    id="modal-pedido"
    class="bg-(--color-background) pb-19 text-(--color-text)"
>
    <div class="contenido flex flex-col gap-4 px-4 pb-4">
        <ModalTopBar mode={mode} />

        <div id="lista-pedido"></div>
        <button
            id="btn-modificar-pedido"
            class="w-fit self-end rounded-full bg-(--color-secondary) px-3 py-1.5 text-bold active:bg-(--color-active-secondary)"
            >Añadir productos</button
        >
    </div>
    <StickyBar modo="review" />
</dialog>

<ProductoTemplate />
<BorrarPedido />

<style>
    .contenido {
        /* padding-bottom: calc(16px + env(safe-area-inset-bottom)); */
        min-height: calc(100% - 59px);
    }
    #modal-pedido {
        position: fixed;
        inset: 0 0 0 auto; 
        margin: 0;
        z-index: 20;
        width: 100vw;
        height: 100dvh;
        max-width: 500px;
        min-height: 100%;
        max-height: 100vh;
        border: none;
        padding: 0;
        box-sizing: border-box;
        display: none;
        translate: 100vw;

        transition-property: overlay, display, translate;
        transition-duration: 0.4s;
        transition-behavior: allow-discrete;
    }
    #modal-pedido[open] {
        display: block;
        translate: 0;
        @starting-style {
            translate: 100vw;
        }
    }

</style>
