<div
    class="badges mb-3 flex w-[calc(100%-20px)] max-w-125 items-end justify-around rounded-2xl py-3 px-1 text-sm select-none gap-8"
>
    <p>
        <StarIcon
            width={20}
            height={20}
            fill="var(--color-background)"
            class:list={"inline text-center"}
        />
        <span>{rating} ({userRatingCount})</span>
        <span>Valoración</span>
    </p>
    <p>
        <DeliveryTimeIcon
            width={20}
            height={20}
            fill="var(--color-background)"
            class:list={"inline text-center"}
        />
        <span>{tiempoEntrega}</span>
        <span>Entrega</span>
    </p>
    <p>
        <DeliveryIcon
            width={25}
            height={25}
            fill="var(--color-background)"
            class:list={"inline text-center"}
        />
        <span id="valor-entrega" class="mt-1!">
            {textoParaMostrarValorEntrega}
            <button id="info-btn" class={`relative ${pagoExterno ? '' : 'visually-hidden'}`} aria-label="Información de envío">
                ⓘ
            <div id="tooltip"
                class="pointer-events-none absolute bottom-full right-1/2 z-50 mb-2 hidden w-48 translate-x-1/12 rounded bg-gray-800 p-2 text-xs text-white shadow-lg">
                    El valor del domicilio es adicional, debe ser cancelado directamente al domiciliario y puede variar según su ubicación.
        <div class="absolute top-full left-11/12 -translate-x-1/2 border-8 border-transparent border-t-gray-800"></div>
    </div>
        </span>
            
            </button>
            
        </span>
        <span>Envío</span>
    </p>
</div>


<script is:inline>
    const infoBtn = document.getElementById("info-btn");
    const tooltip = document.getElementById("tooltip");

    if (infoBtn && tooltip) {
        // Mostrar / Ocultar al tocar el icono
        infoBtn.addEventListener("click", (e) => {
            e.stopPropagation(); // Evita que el click suba al document
            tooltip.classList.toggle("hidden");
        });

        // Cerrar si el usuario toca en cualquier otra parte de la pantalla
        document.addEventListener("click", () => {
            tooltip.classList.add("hidden");
        });
    }
</script>

<style>
    @import "tailwindcss";
    p {
        @apply w-full text-center bg-(--accent) rounded-full aspect-square flex flex-col justify-center items-center text-white uppercase font-medium;
    }
    span {
        @apply block not-last:mt-2 last:text-xs;
    }
</style>
