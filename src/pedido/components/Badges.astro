---
import StarIcon from "@assets/Star.svg";
import DeliveryIcon from "@assets/motorbike.svg";
import DeliveryTimeIcon from "@assets/deliveryTime.svg";

const { rating, userRatingCount, tiempoEntrega, valorEntrega } = Astro.props;

const formatEntrega = (valor) => {
    const num = Number(valor);
    if (valor === "" || isNaN(num)) return valor; // Retorna el texto tal cual ("Adicional", etc.)
    if (num === 0) return "Gratis";
    return `$${num.toLocaleString("es-CO")}`; // Ejemplo: $5.000
};

const pagoExterno = isNaN(Number(valorEntrega));
const textoParaMostrarValorEntrega = formatEntrega(valorEntrega);
