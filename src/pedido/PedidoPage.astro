---
import BaseLayout from "@layouts/BaseLayout.astro";
import Footer from "@layoutsFooter.astro";
import Menu from "@pedido/sections/Menu.astro";
import CategoryNav from "@pedido/sections/CategoryNav.astro";
import ImageViewer from "@components/sections/ImageViewer.astro";
import StickyBar from "@components/sections/StickyBar.astro";
import Modal from "@pedido/sections/Modal.astro";
import Header from "@headers/template/Header.astro";
import Badges from "@pedido/components/Badges.astro";
import HeaderRouter from "@headers/HeaderRouter.astro";

const { tenant, head, styles, header, badges, contact, logo, menu, menuMap, categorias, footer } = Astro.props;
const modo = "pedido";

---

<BaseLayout head={head} styles={styles}>
    <div
        id="datos"
        data-direccionlocal={contact.direccion}
        data-telefono={contact.telefono}
        data-valorentrega={badges.valorEntrega}
        hidden
    >
    </div>
    <HeaderRouter tenant={tenant} header={header} page="pedido"/>

    <main id="main-menu" class="flex flex-col items-center justify-center mb-26" data-menuMap={JSON.stringify(menuMap)}>
        <Badges {...badges} />
        <h1 class="invisible h-0">Menú</h1>
        <CategoryNav categorias={categorias} />
        <Menu menuPorCategoria={menu} modo={modo} />
        <ImageViewer />
        <Modal mode={modo} />
        <StickyBar modo={modo} />
    </main>
</BaseLayout>

<script is:inline>
    const menuData = document.getElementById('main-menu')?.getAttribute('data-menuMap');
    const PRODUCTS_MAP = menuData ? JSON.parse(menuData) : {};
</script>

<script src="../scripts/menu/viewimg.js" />
<script src="../scripts/order/init.js"></script>

<style is:global>
    .cerrado {
        display: none !important;
    }
    .ocultar {
        visibility: hidden;
    }
    /* En tu CSS */
</style>
