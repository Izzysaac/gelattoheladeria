---
import Hero from "../../layouts/Hero.astro";
import Layout from "../../layouts/Layout.astro";

import "../../styles/themes/granpollo.css"

const fetchAndGroup = async () => {
    const url =
        "https://opensheet.elk.sh/1NbSsEokxqqUM_zXYzQLpL12BiAyTw22HbWR7q30xRGM/granpollo-info";

    const res = await fetch(url);
    const data = await res.json();

    const grouped = data.reduce((acc, item) => {
        if (!acc[item.clave]) {
            acc[item.clave] = [];
        }
        acc[item.clave].push(item);
        return acc;
    }, {});

    return {
        titulo: grouped.titulo?.[0]?.valor ?? "",
        descripcion: grouped.descripcion?.[0]?.valor ?? "",
        logo: grouped.logo?.[0]?.valor ?? "",
        botones: grouped.boton ?? [],
        socials: grouped.social ?? [],
    };
};

const grouped = await fetchAndGroup();
const titulo = grouped.titulo
const descripcion = grouped.descripcion
const logo = grouped.logo


---
<Layout titulo={titulo} descripcion={descripcion} logo={logo} class:list={"gradient"}>
    <Hero grouped={grouped}/>
<Layout />


<style is:global>    .gradient{
        background: #ffffff;
    }
</style>