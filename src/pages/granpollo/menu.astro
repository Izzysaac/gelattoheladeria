---
import Pedidos from "../../components/Pedidos.astro";
import Layout from "../../layouts/Layout.astro";

import "../../styles/themes/granpollo.css"

const fetchAndGroupMenu = async () => {
    const url =
        "https://opensheet.elk.sh/1NbSsEokxqqUM_zXYzQLpL12BiAyTw22HbWR7q30xRGM/mandioka-menu";

    // Fetch JSON desde Google Sheets
    const res = await fetch(url);
    const data = await res.json();

    // Agrupar por categoría
    const grouped = {};
    data.forEach((item: any) => {
        const cat = item.categoria || "Sin categoría";
        if (!grouped[cat]) grouped[cat] = [];
        grouped[cat].push(item);
    });

    return grouped;
};

const menuPorCategoria = await fetchAndGroupMenu();

