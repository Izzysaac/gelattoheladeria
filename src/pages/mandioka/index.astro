---
import Hero from "../../layouts/Hero.astro";
import Layout from "../../layouts/Layout.astro";

import "../../styles/themes/mandioka.css"

const fetchAndGroup = async () => {
    const url =
        "https://opensheet.elk.sh/1NbSsEokxqqUM_zXYzQLpL12BiAyTw22HbWR7q30xRGM/mandioka-info";

    const res = await fetch(url);
    const data = await res.json();

    const grouped = data.reduce((acc, item) => {
        if (!acc[item.clave]) {
            acc[item.clave] = [];
        }
        acc[item.clave].push(item);
        return acc;
    }, {});

    return {
        titulo: grouped.titulo?.[0]?.valor ?? "",
        descripcion: grouped.descripcion?.[0]?.valor ?? "",
        logo: grouped.logo?.[0]?.valor ?? "",
        botones: grouped.boton ?? [],
        socials: grouped.social ?? [],
    };
};

const grouped = await fetchAndGroup();

---
<Layout class:list={"gradient"}>
    <Hero grouped={grouped}/>
<Layout />


<style is:global>
    .gradient{
        background: #505050;
        background: radial-gradient(circle,rgba(80, 80, 80, 1) 1%, rgba(64, 64, 64, 1) 62%, rgba(32, 32, 32, 1) 100%);
    }
</style>