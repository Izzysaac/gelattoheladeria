---
import { buildTenantData } from "@lib/buildTenantData";

const { tenant, data } = await buildTenantData("eventos");

if (!tenant.pages.eventos) return Astro.redirect("/");

 function toSlugPage(text: string) {
        return text
            .toLowerCase()
            .replace(/[รกร รครข]/g, "a")
            .replace(/[รฉรจรซรช]/g, "e")
            .replace(/[รญรฌรฏรฎ]/g, "i")
            .replace(/[รณรฒรถรด]/g, "o")
            .replace(/[รบรนรผรป]/g, "u")
            .replace(/\s+/g, "-")
            .replace(/[^a-z0-9รฑ-]/g, "")
            .replace(/-+/g, "-")
            .replace(/^-+|-+$/g, "");
    }   

export async function getStaticPaths() {

	function toSlug(text: string) {
        return text
            .toLowerCase()
            .replace(/[รกร รครข]/g, "a")
            .replace(/[รฉรจรซรช]/g, "e")
            .replace(/[รญรฌรฏรฎ]/g, "i")
            .replace(/[รณรฒรถรด]/g, "o")
            .replace(/[รบรนรผรป]/g, "u")
            .replace(/\s+/g, "-")
            .replace(/[^a-z0-9รฑ-]/g, "")
            .replace(/-+/g, "-")
            .replace(/^-+|-+$/g, "");
    }

    const { tenant, data } = await buildTenantData("eventos");

    if (!tenant.pages.eventos) return [];

    const botones = data?.eventos?.botones ?? [];
    return botones.map((boton) => ({
        params: { slug: toSlug(boton.nombre) },
        props: { boton }, // solo pasar el botรณn especรญfico
    }));
}

const { slug } = Astro.params;
const botones = data?.eventos?.botones ?? [];
const evento = botones.find((b) => toSlugPage(b.nombre) === slug) ?? null;
---

{
    evento ? (
        <div>
            <h1>{evento.nombre}</h1>
            <p>{evento.descripcion}</p>
            {evento.media && <img src={evento.media} alt={evento.nombre} />}
        </div>
    ) : (
        <p>Evento no encontrado</p>
    )
}
