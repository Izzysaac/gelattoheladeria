---
import BaseLayout from "@layouts/BaseLayout.astro";
import Footer from "@layouts/Footer.astro";
import { buildTenantData } from "@lib/buildTenantData";
import { toSlugPage } from "@scripts/utils";

const { tenant, data } = await buildTenantData("eventos");

if (!tenant.pages.eventos) return Astro.redirect("/");

export async function getStaticPaths() {

    const { tenant, data } = await buildTenantData("eventos");

    if (!tenant.pages.eventos) return [];

    const botones = data?.eventos?.botones ?? [];
    return botones.map((boton) => ({
        params: { slug: toSlugPage(boton.nombre) },
        props: { boton, data },
    }));
}

const { slug } = Astro.params;
const botones = data?.eventos?.botones ?? [];
const evento = botones.find((b) => toSlugPage(b.nombre) === slug) ?? null;

const contacto = data?.eventos?.contacto ?? null;

---


<BaseLayout styles={data.estilos}>

{
    evento ? (

    <div class="max-w-125 m-auto">
        
        <div>
            <img src={evento.media} alt={evento.nombre} />
        </div>

        <main class="px-2.5 py-6 flex flex-col">

            <h1 class="text-center text-title">{evento.nombre}</h1>
            <p class="text-pretty">{evento.descripcion}</p>
            <a href={contacto.descripcion} class="m-auto block bg-(--color-primary) text-(--color-on-primary) rounded-full px-3 py-2 mt-4">{contacto.nombre}</a>

        </main>

    </div>

    ) : (
        <p>Evento no encontrado</p>
    )
}

<Footer {...data.footer}/>

</BaseLayout>