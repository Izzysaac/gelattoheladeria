---
import BaseLayout from "@layouts/BaseLayout.astro";
import EventosRouter from "@components/routers/EventosRouter.astro";
import Footer from "@layouts/Footer.astro";

const { head, styles, eventos, footer, tenant } = Astro.props;

---

<BaseLayout head={head} styles={styles}>

    <EventosRouter tenant={tenant} {...eventos} />

    <Footer {...footer} class:list={"mt-26"}/>

</BaseLayout>
