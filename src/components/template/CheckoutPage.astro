---
import BaseLayout from "@layouts/BaseLayout.astro";
import ModalTopBar from "@components/ui/ModalTopBar.astro";
import StickyBar from "@components/sections/StickyBar.astro";

import ResumenPedido from "@components/checkout/ResumenPedido.astro";

import DataForm from "@components/checkout/DataForm.astro";
import NewResumen from "@components/checkout/NewResumen.astro";

const {  tenant, head, contact, metodosPago } = Astro.props;

const modo = "checkout";

---

<BaseLayout>
    <div
        id="datos"
        data-direccionlocal={contact.direccion}
        data-telefono={contact.telefono}
        hidden
    >
    </div>
    <main id="checkoutMain" class="max-w-125 m-auto flex flex-col gap-8 px-2.5 pb-26">
        <ModalTopBar mode={modo} />
        <DataForm metodosPago={metodosPago}/>
        <NewResumen />
    </main>
    <StickyBar modo={modo} />
</BaseLayout>

<script src="../../scripts/checkout/init.js" />
