---

<dialog id="imageViewer">
    <button id="imageViewerCloseBtn" aria-label="Cerrar" aria-label="Cerrar" class="text-white bg-(--buttons)"
        >✕</button
    >
    <img id="imageViewerImg" data-action="viewImage" />
</dialog>

<style>
    dialog#imageViewer {
        border: none;
        padding: 0;
        background: transparent;
        max-width: 90vw;
        max-height: 90vh;
        margin: auto;
    }

    #imageViewerImg {
        object-fit: contain;
        width: 90vw;
        max-width: 500px;
        height: auto;
        max-height: 90vh;
        border-radius: 12px;
        transition: filter 0.3s ease;
    }

    #imageViewerImg.blurred {
        filter: blur(2px);
    }

    #imageViewerCloseBtn {
        position: absolute;
        top: 12px;
        right: 12px;
        border: none;
        border-radius: 50%;
        width: 36px;
        height: 36px;
        font-size: 18px;
        cursor: pointer;
    }
</style>
