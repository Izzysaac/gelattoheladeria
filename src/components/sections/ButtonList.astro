---
const { botones, pagina } = Astro.props;

import { toSlugPage } from "@scripts/utils.js";

---

{
    pagina === "main" &&
        
        <nav class="w-9/12 max-w-125 m-auto mb-6 mt-6 px-2.5 text-(--main-buttons-text)">
            <ul class="flex flex-col justify-center gap-4">
                {
                    botones.map((boton) => (
                        <li>
                            <a
                                href={boton.url}
                                rel="noopener noreferrer"
                                class="text-bold block w-full rounded-full bg-(--main-buttons) px-3 py-3 text-center active:opacity-80 btn-list"
                            >
                                {boton.valor}
                            </a>
                        </li>
                    ))
                }
                <li>
                            <button id="btnListInfo"
                                class="text-bold block w-full rounded-full bg-(--main-buttons) px-3 py-3 text-center active:opacity-80 btn-list"
                            >
                                Información
                            </button>
                        </li>
            </ul>
        </nav>


        <script>
            import { openModal } from "../../scripts/modal.js";
            const infoBtn = document.getElementById("btnListInfo");
            const infoModal = document.getElementById("informacion")
            infoBtn.addEventListener("click", () => {
                openModal("info", infoModal);
            });
        </script>

}


{
    pagina === "eventos" &&
        
        <nav class="w-full max-w-125 m-auto mb-12 mt-6 px-2.5 text-(--main-buttons-text)">
            <ul class="flex flex-col justify-center gap-4">
                {
                    botones.map((boton) => (
                        <li>
                            <a
                                href={`/eventos/${toSlugPage(boton.nombre)}`}
                                rel="noopener noreferrer"
                                class="block w-full rounded-lg bg-(--main-buttons) px-3 py-4 text-center active:opacity-80 text-bold"
                            >
                                {boton.nombre}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </nav>
}



    



