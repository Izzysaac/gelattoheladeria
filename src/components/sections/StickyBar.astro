---
import Action from "@components/ui/Action.astro";

const { modo } = Astro.props;
/* Menu → Order → Review → Fulfillment → Submit (por ahora serian 2*/
---

<div id="stickybar" class="stickybar flex border-t">
    {modo == "menu" && <Action action="order" />}

    {modo == "pedido" && <Action action="review" />}

    {modo == "details" && <Action action="submit" />}
</div>

<style is:global>
    .stickybar {
        position: fixed;
        bottom: 0;
        z-index: 9000;
        width: 100%;
        max-width: 500px;
        background-color: var(--color-background);
        border-top-color: var(--color-separacion);
        padding-bottom: calc(0.5rem + env(safe-area-inset-bottom));
        padding: 8px 12px;
    }

    .stickybarBtn {
        background-color: var(--color-primary);
        color: var(--color-background);
        font-weight: bold;
        border: none;
        border-radius: 25px;
        cursor: pointer;
        padding: 10px 30px;
    }
</style>
