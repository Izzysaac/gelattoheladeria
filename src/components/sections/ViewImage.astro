---

---

<dialog id="dialogImageViewer">
    <button id="dialogImageViewerClose" class="close" aria-label="Cerrar"
        >✕</button
    >
    <img id="imageViewerImg" data-action="viewImage" />
</dialog>

<style>
    dialog#dialogImageViewer {
        border: none;
        padding: 0;
        background: transparent;
        max-width: 90vw;
        max-height: 90vh;
        margin: auto;
    }

    dialog::backdrop {
        background: rgba(0, 0, 0, 0.7);
    }
    #imageViewerImg {
        width: 100%;
        height: auto;
        max-height: 90vh;
        border-radius: 12px;
    }

    .close {
        position: absolute;
        top: 12px;
        right: 12px;
        background: black;
        color: white;
        border: none;
        border-radius: 50%;
        width: 36px;
        height: 36px;
        font-size: 18px;
        cursor: pointer;
    }
</style>
