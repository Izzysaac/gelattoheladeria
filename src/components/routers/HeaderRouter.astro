---
import HeaderNoBanner from "@components/headers/NoBanner.astro";
import HeaderDefault from "@components/headers/Header.astro";
import HeaderCentered from "@components/headers/Centered.astro";
import HeaderClassic from "@components/headers/Classic.astro";
import HeaderBgInfoAbove from "@components/headers/Bg-InfoAbove.astro";
import HeaderBroaster from "@components/headers/BroasterHeader.astro";

const { tenant, header, page } = Astro.props;

console.log(tenant)

const headers = {
    default: HeaderDefault,
    nobanner: HeaderNoBanner,
    centered: HeaderCentered,
    classic: HeaderClassic,
    "bg-info-above": HeaderBgInfoAbove,
    broaster: HeaderBroaster,
};

const TenantMainHeader = headers[tenant.layout.headerVariant] ?? HeaderDefault;
const TenantHeader = headers[tenant.layout.menuHeaderVariant] ?? HeaderDefault;

---

{page === "main" ? <TenantMainHeader {...header} /> : <TenantHeader {...header} />}
