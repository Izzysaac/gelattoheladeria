---
const { principal, botones } = Astro.props;


function toSlug(text) {
  return text
    .toLowerCase()
    .replace(/[찼횪채창]/g, "a")
    .replace(/[챕챔챘챗]/g, "e")
    .replace(/[챠챙챦챤]/g, "i")
    .replace(/[처챵철척]/g, "o")
    .replace(/[첬첫체청]/g, "u")
    .replace(/\s+/g, "-")
    .replace(/[^a-z0-9챰-]/g, "")
    .replace(/-+/g, "-")
    .replace(/^-+|-+$/g, "");
}

---

<div>
    <img src={principal.media}/>
    <h1>{principal.descripcion}</h1>
</div>

{
    botones.map((boton) => (
        <a href={`/eventos/${toSlug(boton.nombre)}`}>{toSlug(boton.nombre)}</a>
    ))
}