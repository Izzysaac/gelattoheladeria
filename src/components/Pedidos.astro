---
import MenuList from "./Menu.astro";
import Modal from "./Modal.astro";
import StickyBar from "./StickyBar.astro";

const {menuPorCategoria} = Astro.props
---

<div class="flex justify-center items-center flex-col py-12">
    <h1 class="text-5xl">Menú</h1>
    <MenuList menuPorCategoria={menuPorCategoria} />
    <StickyBar tipoAccion="ver"/>
    <Modal />
</div>
<script is:inline src="/pedido.js" defer></script>

<style is:global>
    .cerrado {
        display: none !important;
    }
    .ocultar {
        visibility: hidden;
    }
</style>
