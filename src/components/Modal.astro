---
import TipoEntrega from "./TipoEntrega.astro";


// Añadir cerrado al modal
---
<div id="modal-pedido" class="border border-gray-300 rounded p-4 cerrado">
    <div class="contenido flex flex-col gap-4">

        <button id="btn-cerrar-modal" class="w-fit self-end bg-red-500!">✕</button>

        <div id="lista-pedido"></div>

        <TipoEntrega />

        <div id="total-pedido"></div>

        <button id="btn-modificar-pedido" class="bg-orange-500!">Modificar pedido</button>
        <button id="btn-hacer-pedido">Hacer pedido</button>
    </div>
</div>

<template id="item-pedido-template">
    <div
        class="item-pedido my-4 p-4 border border-gray-300 rounded flex gap-8 justify-between items-center"
    >
        <span class="nombre"></span>
        <div class="controles flex items-center">
            <button data-action="remove" class="remove">−</button>
            <span class="cantidad mx-2"></span>
            <button data-action="add" class="add">+</button>
        </div>
        <span class="precio"></span>
    </div>
</template>


<style>
    #modal-pedido {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background-color: rgb(19, 19, 19);
        z-index: 2000;
        width: 100%;
        height: 100%;
        max-width: 500px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }
</style>