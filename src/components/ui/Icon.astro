---
import Instagram from "@assets/instagram.svg";
import Facebook from "@assets/facebook.svg";
import Whatsapp from "@assets/whatsapp.svg";
import LocationIcon from "@assets/location.svg";
import PhoneIcon from "@assets/phone.svg";
import ClockIcon from "@assets/clock.svg"
import MailIcon from "@assets/mail.svg"
import ExternalIcon from "@assets/external.svg"
import TiktokIcon from "@assets/tiktok.svg"
import TicketShape from "@assets/shapes/ticket.svg";


const {
    name,
    width = 25,
    height = 25,
    fill = "currentColor",
    stroke = "currentColor",
    class: className 
    
    } = Astro.props;
    
---

{
    name == "instagram" && (
        <Instagram width={width} height={height} fill={fill} stroke={stroke} class={className} />
    )
}
{
    name == "facebook" && (
        <Facebook width={width} height={height} fill={fill} stroke={stroke} class={className} />
    )
}
{
    name == "whatsapp" && (
        <Whatsapp width={width} height={height} fill={fill} stroke={stroke} class={className} />
    )
}
{
    name == "location" && (
        <LocationIcon width={width} height={height} fill={fill} stroke={stroke} class={className} />
    )
}
{
    name == "phone" && (
        <PhoneIcon width={width} height={height} fill={fill} stroke={stroke} class={className} />
    )
}
{
    name == "clock" && (
        <ClockIcon width={width} height={height} fill={fill} stroke={stroke} class={className} />
    )
}
{
    name == "email" && (
        <MailIcon width={width} height={height} fill={fill} stroke={stroke} class={className} />
    )
}
{
    name == "external" && (
        <ExternalIcon width={width} height={height} stroke={stroke} class={className} />
    )
}
{
    name == "tiktok" && (
        <TiktokIcon width={width} height={height} stroke={stroke} class={className} />
    )
}
{
    name == "ticket" && (
        <TicketShape width={width} height={height} stroke={stroke} class={className} />
    )
}