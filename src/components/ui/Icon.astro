---
import Instagram from "@assets/instagram.svg";
import Facebook from "@assets/facebook.svg";
import Whatapp from "@assets/whatapp.svg";
import LocationIcon from "@assets/location.svg";
import PhoneIcon from "@assets/phone.svg";


const {
    name,
    width = 25,
    height = 25,
    fill = "#FFF",
    stroke = "none",
} = Astro.props;
---

{
    name == "instagram" && (
        <Instagram width={width} height={height} fill={fill} stroke={stroke} />
    )
}
{
    name == "facebook" && (
        <Facebook width={width} height={height} fill={fill} stroke={stroke} />
    )
}
{
    name == "whatapp" && (
        <Whatapp width={width} height={height} fill={fill} stroke={stroke} />
    )
}
{
    name == "location" && (
        <LocationIcon width={width} height={height} fill={fill} stroke={stroke} />
    )
}
{
    name == "phone" && (
        <PhoneIcon width={width} height={height} fill={fill} stroke={stroke} />
    )
}