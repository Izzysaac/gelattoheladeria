---
import StarIcon from "./StarIcon.astro";
import StarClassic from "../assets/star-classic.svg";

const { rating = 0, width, height, style } = Astro.props;

const num = Math.round(Number(rating));
const stars = Array.from({ length: num });
---



{ (style === "classic") && stars.map((_, i) => <StarClassic width={width} height={height} />)}
{ (style === "one-classic") && <StarClassic width={width} height={height} />}
{ (style === "default") && stars.map((_, i) => <StarIcon width={width} height={height} />)}

