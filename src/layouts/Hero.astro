---
import Icon from "@components/ui/Icon.astro";
import Logo from "@components/ui/Logo.astro";

const { titulo, descripcion, logo, botones, socials } = Astro.props;
---

<header
    class="m-auto flex max-w-100 flex-col items-center gap-4 rounded-lg px-8 py-20 text-(--index-text)"
>
    <Logo titulo={titulo} logo={logo} />

    <h1 class="text-xl font-semibold">{titulo}</h1>
    <nav class="w-full">
        <ul class="flex flex-col justify-center gap-2">
            {
                botones.map((boton) => (
                    <li>
                        <a
                            href={boton.url}
                            rel="noopener noreferrer"
                            class="block w-full rounded-lg bg-(--index-buttons) px-3 py-4 text-center text-(--index-buttons-text)"
                        >
                            {boton.valor}
                        </a>
                    </li>
                ))
            }
        </ul>
    </nav>
    <div class="social flex gap-2">
        {
            socials.map((social) => (
                <a
                    href={social.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={social.valor}
                    class="text-(--index-text)/60"
                >
                    {<Icon name={social.valor} height="40" width="40" />}
                </a>
            ))
        }
    </div>
</header>
