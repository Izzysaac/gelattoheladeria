---
import ShapeWave from "@assets/headerShapes/ondulation.svg";
import InfoIcon from "@assets/information.svg";
import LocationIcon from "@assets/location.svg";
import PhoneIcon from "@assets/phone.svg";

const {
    titulo,
    descripcion,
    logo,
    banner,
    horario,
    rating,
    userRatingCount,
    tiempoEntrega,
    valorEntrega,
} = Astro.props;


const bannerUrl = `url('${banner}')`;

---

<header id="mainHeader" class="m-auto flex max-w-125 flex-col items-center text-(--index-text) relative">

    <img src={banner} />

    <!-- Fixed header that appears on scroll OK-->
    <div id="fixedHeader" class="fixed-header max-w-125 sm:hidden">
        <div class="fixed-header-content md:hidden">
            <a href="/" class="fixed-logo-container">
                <img
                    src={logo.logo}
                    alt={logo.titulo}
                    class="fixed-logo"
                />
                <div id="fixedStatusLight" class="fixed-status-light"></div>
            </a>
            
            <h1 id="fixedTitulo" class="fixed-title">{titulo}</h1>
            
            <button id="fixedInfoBtn" class="fixed-info-btn">
                <InfoIcon  
                width={30}
                height={30}
                fill="var(--color-background)"
                class:list={"pointer-events-none"}/>
            </button>
        </div>
    </div>

    <button id="infoBtn" class="fixed right-3 top-3">
            <InfoIcon  
            width={35}
            height={35}
            fill="var(--color-background)"
            class:list={"pointer-events-none"}/>
    </button>

    <div class="w-full p-2.5">
        <div class="flex">
            <a id="logo" href="/" class="relative">
                <img
                    id="logoImg"
                    src={logo.logo}
                    alt={logo.titulo}
                    width="70px"
                    height="70px"
                    class="anchor-img pointer-events-none rounded-full border-3 border-(--color-separacion)"
                    fetchpriority="high"
                    loading="eager"
                />
                <div id="statusLight" class="h-4 w-4 rounded-full border-3 border-(--color-background)"></div>
            </a>

            <div class="px-2.5 flex flex-col justify-center">
                <h1 id="titulo" class="text-xl font-semibold">{titulo}</h1>
                <p id="statusMsg" data-horario={JSON.stringify(horario)} class="text-sm opacity-90"
                ></p>
            </div>
        </div>
        <p class="mt-3">{descripcion}</p>
    </div>

</header>
<dialog id="informacion" class="mt-auto mb-0 max-w-dvh  w-full border-0 border-t backdrop:bg-black backdrop:opacity-70">
    <div class="w-full max-w-125 h-fit bg-(--color-background) text-(--color-text) text-sm">
        <button id="closeInfoBtn" class="absolute top-2 right-2">X</button>
        <div class="flex flex-col gap-4 p-4">
            {
                horario.weekly.map((dia) => {
                    const dayNames = ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado'];
                    const dayName = dayNames[dia.day];
                    const schedule = dia.ranges.map(rango => `${rango.open}-${rango.close}`).join(' ');
                    
                    return (
                        <div class="flex justify-between items-start py-2 border-b border-(--color-separacion)">
                            <span class="font-medium">{dayName}</span>
                            <div class="text-right opacity-80">
                                {dia.ranges.map((rango) => (
                                    <div>{rango.open}-{rango.close}</div>
                                ))}
                            </div>
                        </div>
                    );
                })
            }
        </div>
        
    </div>
</dialog>

<script is:inline>
    const info = document.getElementById("informacion");
    const infoBtn = document.getElementById("infoBtn");
    const fixedInfoBtn = document.getElementById("fixedInfoBtn");
    const fixedHeader = document.getElementById("fixedHeader");
    const mainHeader = document.getElementById("mainHeader");
    const statusLight = document.getElementById("statusLight");
    const fixedStatusLight = document.getElementById("fixedStatusLight");

    // Info modal functionality
    const showModal = () => info.showModal();
    infoBtn.addEventListener("click", showModal);
    fixedInfoBtn.addEventListener("click", showModal);

    info.addEventListener("click", (e) =>
        e.target === info ? info.close() : null,
    );

    // Scroll functionality for fixed header
    let lastScrollY = 0;
    let ticking = false;

    function updateFixedHeader() {
        const scrollY = window.scrollY;
        const headerHeight = mainHeader.offsetHeight;
        
        // Show fixed header when scrolled past the main header
        if (scrollY > headerHeight - 60) {
            fixedHeader.classList.add('show');
        } else {
            fixedHeader.classList.remove('show');
        }

        // Sync status light classes
        if (statusLight && fixedStatusLight) {
            fixedStatusLight.className = statusLight.className.replace('h-4 w-4', '').replace('absolute bottom-1 right-1', '').trim() + ' fixed-status-light';
        }

        lastScrollY = scrollY;
        ticking = false;
    }

    function requestTick() {
        if (!ticking) {
            requestAnimationFrame(updateFixedHeader);
            ticking = true;
        }
    }

    // Throttled scroll listener
    window.addEventListener('scroll', requestTick, { passive: true });

    // Initial check
    updateFixedHeader();
</script>

<script type="module">
    import { updateStatus } from "/status.js";
    updateStatus();
</script>

<style define:vars={{ bannerUrl }}>
    @import "tailwindcss";
    .hero {
        position: relative;
    }

    .wave {
        position: absolute;
        bottom: -1px;
    }

    .info {
        position: absolute;
        top: 0;
        right: 0;
    }

    .open {
        @apply bg-green-500;
    }
    .closed {
        @apply bg-red-500; 
    }
    .closing-soon {
        @apply bg-orange-500;
    }
    .opening-soon {
        @apply bg-blue-500;
    }

    /* Fixed Header Styles */
    .fixed-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        background: var(--color-background);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--color-separacion);
        transform: translateY(-100%);
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        opacity: 0;
        visibility: hidden;
    }

    .fixed-header.show {
        transform: translateY(0);
        opacity: 1;
        visibility: visible;
    }

    .fixed-header-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 500px;
        margin: 0 auto;
        padding: 0.75rem 1rem;
        height: 60px;
    }

    .fixed-logo-container {
        position: relative;
        display: flex;
        align-items: center;
    }

    .fixed-logo {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: 2px solid var(--color-separacion);
        pointer-events: none;
    }

    .fixed-status-light {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        position: absolute;
        bottom: 0;
        right: 0;
        border: 2px solid var(--color-background);
    }

    .fixed-title {
        font-size: 1.125rem;
        font-weight: 600;
        color: var(--index-text);
        margin: 0;
        flex: 1;
        text-align: start;
        padding: 0 1rem;
    }

    .fixed-info-btn {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        border-radius: 50%;
        transition: background-color 0.2s ease;
    }

    .fixed-info-btn:hover {
        background-color: var(--color-separacion);
    }

    /* Animation for elements */
    .fixed-header-content > * {
        animation: slideInUp 0.4s ease-out forwards;
    }

    .fixed-logo-container {
        animation-delay: 0.1s;
    }

    .fixed-title {
        animation-delay: 0.2s;
    }

    .fixed-info-btn {
        animation-delay: 0.3s;
    }

    @keyframes slideInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }


    .anchor-img {
        anchor-name: --logo-image ;
    } 
    #statusLight {
        position: absolute;
        position-anchor: --logo-image ; 
        bottom: calc(anchor(bottom) + 1px);
        right: calc(anchor(right) + 1px);
    }
</style>
 