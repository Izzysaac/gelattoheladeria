---
const { titulo, direccion, telefono, class: className } = Astro.props;
---

<footer class=`footer py-6 text-(---color-text)/50 ${className}`>
    <p>
        &copy; <span id="year">2026</span>
        <strong>{titulo}</strong>. Todos los derechos reservados.
    </p>
    <p class="mt-1.5">
        <a href="https://wa.me/573163896572"
            >Powered by <span class="font-bold">Isaac</span></a
        >
    </p>
</footer>

<style>
    .footer {
        font-size: xx-small;
        text-align: center;
    }
</style>

<script is:inline>
    document.getElementById("year").textContent = String(new Date().getFullYear())
</script>
