---
import "@styles/base.css";
import "@styles/themes/default.css";
import "@styles/themes/mandioka.css";
import "@styles/themes/granpollo.css";
import "@styles/themes/raicesgourmet.css";
import "@styles/themes/broasterchefpitalito.css";

import { loadTenant } from "@lib/loadTenant";
import Head from "./Head.astro";

const theme = loadTenant().theme;
const { head } = Astro.props;
---

<!doctype html>
<html lang="es" data-theme={theme}>
    <Head {...head} />
    <body>
        <slot />
    </body>
</html>

<style is:global>
    @import "tailwindcss";
    .no-scroll {
        overflow: hidden;
    }

    .is-locked {
        position: fixed;
        width: 100%;
        height: 100%;
        overflow: hidden;
        /* Evita saltos visuales si hay scrollbar en desktop */
        padding-right: var(--scrollbar-width, 0px);
    }

    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
        background-color: var(--color-background);
        color: var(--color-text);
        font-family: Verdana, Geneva, Tahoma, sans-serif;
        /* scroll-behavior: smooth; */
        overflow-y: auto; /*¿? */
        -webkit-overflow-scrolling: touch; /*¿? */
    }

    /* dialog[open] {
        animation: fadeIn 200ms ease-out;
    } */
    dialog::backdrop {
        background: rgba(0, 0, 0, 0.7);
    }

    button {
        touch-action: manipulation;
        cursor: pointer;
    }
    /* @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(8px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    } */
</style>
