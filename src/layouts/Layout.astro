---

import Head from "./Head.astro";

const { titulo, descripcion, logo,  class: className } = Astro.props; 
---

<!doctype html>
<html lang="es">

	<Head titulo={titulo} descripcion={descripcion} logo={logo}/>

	<body class:list={className}>
		<slot />
	</body>
</html>

<style is:global>
	@import "tailwindcss";	
	.no-scroll {
		overflow: hidden;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		background-color: var(--color-background);
		color: var(--color-text);
		font-family:  Verdana, Geneva, Tahoma, sans-serif;
	}

	html {
		scroll-behavior: smooth;
	}
</style>




