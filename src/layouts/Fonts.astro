---
const { fonts } = Astro.props;

const fontList = fonts?.preload?.map(f => ({
  href: f.href,
  name: f.familyName,
  weight: f.weight ?? 400,
  style: f.style ?? "normal",
})) ?? [];

const regular = fontList[0];
const medium = fontList[1];
const semibold = fontList[2];
const bold = fontList[3];
const title = fontList[4];

---
<script is:inline define:vars={{ fontList, regular, medium, semibold, bold, title }}>
  if (Array.isArray(fontList) && fontList.length > 0) {

    const style = document.createElement("style");
    style.id = "tenant-fonts";

    // 1️⃣ Registrar @font-face
    const fontFaces = fontList.map(f => `
      @font-face {
        font-family: "${f.name}";
        src: url(${f.href}) format("woff2");
        font-weight: ${f.weight};
        font-style: ${f.style};
        font-display: swap;
      }
    `).join("\n");


    // 3️⃣ Generar clases directamente
    const classes = `
      .text-regular {
        font-family: "${regular?.name ?? "system-ui"}", system-ui, sans-serif;
        font-weight: ${regular?.weight ?? 400};
      }

      .text-medium {
        font-family: "${medium?.name ?? "system-ui"}", system-ui, sans-serif;
        font-weight: ${medium?.weight ?? 500};
      }

      .text-semibold {
        font-family: "${semibold?.name ?? "system-ui"}", system-ui, sans-serif;
        font-weight: ${semibold?.weight ?? 600};
      }

      .text-bold {
        font-family: "${bold?.name ?? "system-ui"}", system-ui, sans-serif;
        font-weight: ${bold?.weight ?? 700};
      }

      .text-title {
        font-family: "${title?.name ?? "system-ui"}", system-ui, sans-serif;
        font-weight: ${title?.weight ?? 700};
      }
      
      body {
        font-family: "${regular?.name ?? "system-ui"}", system-ui, sans-serif;
        font-weight: ${regular?.weight ?? 400};
      }
    `;

    style.textContent = fontFaces + classes;

    document.head.appendChild(style);
  }
</script>