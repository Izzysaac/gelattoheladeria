---
import EventoDefault from "@eventos/template/EventoDefault.astro";
import EventoClassic from "@eventos/template/EventoClassic.astro";

const { tenant, principal, botones } = Astro.props;

const eventosComponents = {
    default: EventoDefault,
    classic: EventoClassic
};

const TenantEvent = eventosComponents[tenant.layout.eventosVariant] ?? EventoDefault;

---

<TenantEvent principal={principal} botones={botones} />
