---
import ButtonList from "@components/sections/ButtonList.astro";
import { toSlugPage } from "@scripts/utils.js";
import { CldImage } from 'astro-cloudinary';
import EventButtons from "../components/EventButtons.astro";

const { principal, botones } = Astro.props;
---

<div class="max-w-125 m-auto">

    <div class="bg-(--color-primary) pb-5">
        <img src={principal.media}/>
    </div>
    
    <main>
        <h1 class="visually-hidden">Eventos</h1>
        <p class="text-center mt-6 text-pretty px-2.5">{principal.descripcion}</p>
    
        <!-- <ButtonList botones={botones} pagina="eventos"/> -->
        <EventButtons botones={botones}/>

    </main>
</div>
