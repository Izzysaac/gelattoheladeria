---
import BaseLayout from "@layouts/BaseLayout.astro";
import EventosRouter from "@eventos/EventosRouter.astro";
import Footer from "@layouts/Footer.astro";

const { tenant, head, styles, eventos, footer } = Astro.props;

---

<BaseLayout head={head} styles={styles}>

    <EventosRouter tenant={tenant} {...eventos} />

    <Footer {...footer} class:list={"mt-26"}/>

</BaseLayout>
