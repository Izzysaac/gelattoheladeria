---
import InfoIcon from "@assets/information.svg";
import Informacion from "@components/sections/Informacion.astro";
import BannerWave from "@assets/shapes/banner-wave.svg";

const {
    titulo,
    descripcion,
    logo,
    banner,
    horario,
    socials,
    direccion,
    telefono,
    correo,
} = Astro.props;

---

<header
    id="mainHeader"
    class="m-auto flex max-w-120 flex-col items-center text-(--main-text) mb-2"
>
    <button id="infoBtn"
        class="fixed top-3 right-3 rounded-full group z-10"
        aria-label="Más información"
    >
        <InfoIcon
            width={35}
            height={35}
            fill="var(--color-background)"
            stroke="var(--color-text)"
            class:list={"pointer-events-none group-active:fill-(--color-active-secondary)"}
            aria-label="Más información"
        />
    </button>
    <div class="w-full text-(--background-color) relative">
        <img
            id="banner"
            src={banner}
            alt=`Imagen de presentacion de ${titulo}`
            fetchpriority="high"
            loading="eager"
            width="820"
            height="462"
        />
        <BannerWave class="w-full h-auto absolute -bottom-2" />
    </div>
    <div id="anchorContainer" class="flex w-full p-2.5 -mt-8 z-10">
        <a id="logo" href="/" class="relative bg-white rounded-full p-0.5 flex items-center w-17.5 h-17.5 shrink-0">
            <img
                id="logoImg"
                src={logo.logo}
                alt={logo.titulo}
                width="70px"
                height="70px"
                class="anchor-img pointer-events-none"
                fetchpriority="high"
                loading="eager"
            />
            <div
                id="statusLight"
                class="h-4.5 w-4.5 rounded-full border-3 border-(--color-background)"
            >
            </div>
        </a>

        <div class="flex flex-col justify-center px-2.5">
            <h1 id="titulo" class="text-xl text-title">{titulo}</h1>
            <p
                id="statusMsg"
                data-horario={JSON.stringify(horario)}
                class="text-sm opacity-90 header-status-message"
            >
                Cargando ...
            </p>
        </div>
    </div>

    <p class="px-2.5 opacity-95 header-descripcion">{descripcion}</p>
    <Informacion {...Astro.props} />
</header>

<script src="../../scripts/modal.js"></script>
<script src="../scripts/information.js"></script>
<script src="../scripts/status/index.js"></script>

<style>
    @import "tailwindcss";

    .open {
        @apply bg-green-500;
    }
    .closed {
        @apply bg-red-500;
    }
    .closing-soon {
        @apply bg-orange-500;
    }
    .opening-soon {
        @apply bg-blue-500;
    }
    /* Status light on logo */
    .anchor-img {
        anchor-name: --logo-image;
    }
    #statusLight {
        position: absolute;
        bottom: 3px;
        right: 3px;
    }
</style>
