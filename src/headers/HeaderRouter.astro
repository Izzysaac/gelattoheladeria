---
import HeaderNoBanner from "@headers/template/NoBanner.astro";
import HeaderDefault from "@headers/template/Header.astro";
import HeaderCentered from "@headers/template/Centered.astro";
import HeaderClassic from "@headers/template/Classic.astro";
import HeaderBgInfoAbove from "@headers/template/Bg-InfoAbove.astro";
import HeaderBroaster from "@headers/template/BroasterHeader.astro";
import HeaderUppercase from "@headers/template/HeaderUppercase.astro";

const { tenant, header, page } = Astro.props;

const headers = {
    default: HeaderDefault,
    defaultUppercase: HeaderUppercase,
    nobanner: HeaderNoBanner,
    centered: HeaderCentered,
    classic: HeaderClassic,
    "bg-info-above": HeaderBgInfoAbove,
    broaster: HeaderBroaster,
};

const TenantMainHeader = headers[tenant.layout.headerVariant] ?? HeaderDefault;
const TenantHeader = headers[tenant.layout.menuHeaderVariant] ?? HeaderDefault;

---

{page === "main" ? <TenantMainHeader {...header} /> : <TenantHeader {...header} />}
